// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Form {
  id     Int    @id @default(autoincrement())
  userId String

  published   Boolean @default(false)
  name        String
  description String  @default("")
  content     String  @default("[]")

  visits      Int @default(0)
  submissions Int @default(0)

  shareUrl       String           @default(uuid())
  FormSubmission FormSubmission[]
  FormEvent      FormEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
}

model FormSubmission {
  id     Int @id @default(autoincrement())
  formId Int

  form           Form   @relation(fields: [formId], references: [id])
  content        String
  timeToComplete Int?
  device         String @default("unknown")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FormEvent {
  id        Int    @id @default(autoincrement())
  formId    Int
  form      Form   @relation(fields: [formId], references: [id])

  sessionId String
  type      String   // "form_start", "field_interaction", "field_error", "form_abandon"
  fieldId   String?
  metadata  String?  // JSON string for extra data (device, user-agent, etc.)

  createdAt DateTime @default(now())

  @@index([formId, type])
  @@index([formId, sessionId])
}
